DATABASE_URL="postgresql://user:password@localhost:5432/image_magic"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# 32-byte key, base64-encoded（用 `openssl rand -base64 32` 產生），用於加密存在
# User.driveRefreshToken 與 ProviderApiKey.encryptedKey 的密文（如 Drive refresh
# token、使用者自備的 provider API key）。
DRIVE_TOKEN_ENCRYPTION_KEY=""

# "claude" provider（站方提供、共用一組額度）實際出圖時用的圖片生成 API key
# （目前接 OpenAI Images API）。
AI_IMAGE_PROVIDER_API_KEY=""

# "claude" provider 用來改寫/優化 prompt 的 Anthropic API key（Claude 本身沒有
# 圖片生成 API，僅負責文字改寫，實際出圖仍由 AI_IMAGE_PROVIDER_API_KEY 負責）。
ANTHROPIC_API_KEY=""

# 全站共用密碼，使用者選擇 "claude" provider 時需輸入此密碼才能使用站方提供的
# 額度（避免額度被陌生人濫用）；用 `openssl rand -base64 24` 之類的指令產生即可。
DEFAULT_PROVIDER_PASSWORD=""
