generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id            String          @id @default(cuid())
  googleId      String          @unique
  email         String          @unique
  name          String?
  avatarUrl     String?
  driveFolderId String?
  driveRefreshToken String?
  createdAt     DateTime        @default(now())

  stylePresets    StylePreset[]
  generationJobs  GenerationJob[]
  images          Image[]
  tags            Tag[]
  usageLogs       UsageLog[]
  providerApiKeys ProviderApiKey[]
}

model ProviderApiKey {
  id            String   @id @default(cuid())
  userId        String
  provider      String
  encryptedKey  String
  model         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model StylePreset {
  id         String        @id @default(cuid())
  userId     String
  name       String
  basePrompt String
  createdAt  DateTime      @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fields PromptField[]
}

model PromptField {
  id            String       @id @default(cuid())
  stylePresetId String?
  key           String
  value         String
  order         Int          @default(0)

  stylePreset StylePreset? @relation(fields: [stylePresetId], references: [id], onDelete: Cascade)
}

enum JobStatus {
  pending
  success
  failed
}

model GenerationJob {
  id           String    @id @default(cuid())
  userId       String
  provider     String
  model        String?
  promptFinal  String
  params       Json?
  status       JobStatus @default(pending)
  resultUrl    String?
  error        String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  images Image[]
}

model UsageLog {
  id       String   @id @default(cuid())
  userId   String
  provider String
  date     DateTime
  count    Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, date])
}

model Image {
  id            String   @id @default(cuid())
  userId        String
  jobId         String?
  driveFileId   String?
  driveViewUrl  String?
  thumbnailUrl  String?
  title         String?
  description   String?
  aiCaption     String?
  aiTagSuggestions Json?
  aiRecognitionError String?
  width         Int?
  height        Int?
  embedding     Unsupported("vector(1536)")?
  createdAt     DateTime @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  GenerationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  tags ImageTag[]
}

model Tag {
  id     String @id @default(cuid())
  userId String
  name   String

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  images ImageTag[]

  @@unique([userId, name])
}

model ImageTag {
  imageId String
  tagId   String

  image Image @relation(fields: [imageId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([imageId, tagId])
}
