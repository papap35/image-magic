# 一般查詢用，走 Transaction pooler（如 Supabase 的 Connection Pooler，通常是
# pooler host 的 port 6543）。記得加上 `?pgbouncer=true`，否則 serverless 環境
# 下多個 instance 共用底層連線時，Prisma 的 prepared statement 會互相衝突，出現
# `prepared statement "sX" already exists`（PostgresError 42P05）。
DATABASE_URL="postgresql://user:password@localhost:5432/image_magic?pgbouncer=true"

# 給 `prisma migrate deploy` / `prisma db push` 用，需要支援 session 層級的
# prepared statement，因此**不要用真正的直連 host**（Supabase 的直連 host 預設
# 只有 IPv6，GitHub Actions/Vercel 都是 IPv4-only，連不上）。Supabase 請改用同一
# 個 pooler host 的 Session pooler（port 5432，而非真正直連的 db.xxx.supabase.co），
# 兩種 pooler 模式都支援 IPv4。本機開發可以跟 DATABASE_URL 設一樣（不需要
# pgbouncer 參數）。
DIRECT_URL="postgresql://user:password@localhost:5432/image_magic"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# 32-byte key, base64-encoded（用 `openssl rand -base64 32` 產生），用於加密存在
# User.driveRefreshToken 與 ProviderApiKey.encryptedKey 的密文（如 Drive refresh
# token、使用者自備的 provider API key）。
DRIVE_TOKEN_ENCRYPTION_KEY=""

# 站方共用的 OpenAI API key，與「出圖 provider」選擇無關：目前用於語意搜尋的
# embeddings 與圖片自動辨識／打標籤的 vision captioning。
AI_IMAGE_PROVIDER_API_KEY=""

# 用於「出圖前用 Claude 改寫/優化 prompt」這個選用功能（Claude 本身沒有圖片生成
# API，僅負責文字改寫；實際出圖一律由使用者在 provider 選單自備的 API key 負責，
# 目前支援 openai、huggingface 兩種 BYOK provider）。
ANTHROPIC_API_KEY=""

# 全站共用密碼，使用者勾選「用 Claude 改寫 prompt」時需輸入此密碼才能使用站方的
# ANTHROPIC_API_KEY 額度（避免額度被陌生人濫用）；用 `openssl rand -base64 24`
# 之類的指令產生即可。
PROMPT_ENHANCEMENT_PASSWORD=""
